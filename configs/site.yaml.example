# Site-specific configuration
# Copy to site.yaml and customize for your environment
# Generated by: uv run python3 scripts/setup.py

project_name: "my-project"
description: "My research project"
wandb_project: "my-project"

# Infrastructure
default_cluster: "vegi"
default_device: "1x4090"

paths:
  workspace: "/workspace/$USER"
  data: "/data/$USER"
  nas: ["/nas1", "/nas2"]

# LAIT Lab clusters (modify if using different infrastructure)
clusters:
  - name: "soda"
    partitions: ["R3090", "A100"]
    gpus: "10x 3090 (soda-02), 8x 3090 (soda-03), 8x A100 (soda-04)"
    devices: ["1x3090", "2x3090", "4x3090", "8x3090", "1xa100", "2xa100", "4xa100", "8xa100"]
  
  - name: "vegi"
    partitions: ["R4090", "A6000", "RTXPRO6000"]
    gpus: "8x 4090/node, 8x A6000, 8x Pro6000 96GB"
    devices: ["1x4090", "2x4090", "4x4090", "8x4090", "1xa6000", "2xa6000", "4xa6000", "8xa6000", "1xpro6000", "2xpro6000", "4xpro6000", "8xpro6000"]
  
  - name: "potato"
    partitions: ["A6000"]
    gpus: "6x A6000/node"
    devices: ["1xa6000", "2xa6000", "4xa6000", "6xa6000"]
